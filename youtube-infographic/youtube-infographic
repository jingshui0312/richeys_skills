#!/bin/bash
# YouTube Infographic Generator CLI wrapper

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_SCRIPT="$SCRIPT_DIR/scripts/youtube_extract.py"

# Use system python3
PYTHON="python3"

# Check and install youtube-transcript-api if needed
if ! $PYTHON -c "import youtube_transcript_api" 2>/dev/null; then
    echo "Installing youtube-transcript-api..." >&2
    $PYTHON -m pip install -q --break-system-packages youtube-transcript-api 2>/dev/null || \
    $PYTHON -m pip install -q youtube-transcript-api 2>/dev/null || true
fi

# Execute
$PYTHON "$PYTHON_SCRIPT" "$@"
